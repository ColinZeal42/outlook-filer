<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>c41a2c93-abb6-4276-8f11-a47e71353c65</Id>
  <Version>1.0.0.6</Version>
  <ProviderName>HMF</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="HMF Email Filer"/>
  <Description DefaultValue="Files sent emails into matching case folders."/>

  <IconUrl DefaultValue="https://ColinZeal42.github.io/outlook-filer/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://ColinZeal42.github.io/outlook-filer/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://ColinZeal42.github.io/outlook-filer"/>
  <AppDomains>
    <AppDomain>https://ColinZeal42.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://ColinZeal42.github.io/outlook-filer/dialog.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets>
          <bt:Set Name="Mailbox" MinVersion="1.12"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <Runtimes>
            <Runtime resid="Commands.Html" lifetime="short"/>
          </Runtimes>
          <DesktopFormFactor>
            <FunctionFile resid="Commands.Html"/>
            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnMessageSend" FunctionName="onMessageSend" SendMode="SoftBlock"/>
              </LaunchEvents>
              <SourceLocation resid="Commands.Html"/>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://ColinZeal42.github.io/outlook-filer/commands.js"/>
          <bt:Url id="Commands.Html" DefaultValue="https://ColinZeal42.github.io/outlook-filer/commands.html"/>
          <bt:Url id="Dialog.Url" DefaultValue="https://ColinZeal42.github.io/outlook-filer/dialog.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="AddInName" DefaultValue="HMF Email Filer"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="AddInDescription" DefaultValue="Files sent emails into matching case folders."/>
        </bt:LongStrings>
      </Resources>

      <WebApplicationInfo>
        <Id>75dc31c8-0515-4c64-849c-3958218e2c5f</Id>
        <Resource>api://hmflaw.com/75dc31c8-0515-4c64-849c-3958218e2c5f</Resource>
        <Scopes>
          <Scope>profile</Scope>
          <Scope>openid</Scope>
          <Scope>https://graph.microsoft.com/Mail.ReadWrite</Scope>
        </Scopes>
      </WebApplicationInfo>
    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
