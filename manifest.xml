<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <Id>c41a2c93-abb6-4276-8f11-a47e71353c65</Id>
  <Version>3.0.1.2</Version>
  <ProviderName>HMF</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="HMF Email Filer"/>
  <Description DefaultValue="Files sent emails into matching case folders."/>

  <IconUrl DefaultValue="https://ColinZeal42.github.io/outlook-filer/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://ColinZeal42.github.io/outlook-filer/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://ColinZeal42.github.io/outlook-filer"/>
  <AppDomains>
    <AppDomain>https://ColinZeal42.github.io</AppDomain>
  </AppDomains>

  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3"/>
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://ColinZeal42.github.io/outlook-filer/dialog.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <Permissions>ReadWriteMailbox</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read"/>
  </Rule>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets>
          <bt:Set Name="Mailbox" MinVersion="1.12"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <Runtimes>
            <Runtime resid="Setup.Html" lifetime="long"/>
            <Runtime resid="Commands.Html" lifetime="long"/>
          </Runtimes>
          <DesktopFormFactor>
            <FunctionFile resid="Commands.Html"/>

            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="hmfGroup">
                  <Label resid="AddInName"/>
                  <Control xsi:type="Button" id="hmfSetupButton">
                    <Label resid="SetupLabel"/>
                    <Supertip>
                      <Title resid="SetupLabel"/>
                      <Description resid="SetupDesc"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon16"/>
                      <bt:Image size="32" resid="Icon32"/>
                      <bt:Image size="80" resid="Icon80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Setup.Html"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnMessageSend" FunctionName="onMessageSend" SendMode="SoftBlock"/>
              </LaunchEvents>
              <SourceLocation resid="Commands.Html"/>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon16" DefaultValue="https://ColinZeal42.github.io/outlook-filer/assets/icon-64.png"/>
          <bt:Image id="Icon32" DefaultValue="https://ColinZeal42.github.io/outlook-filer/assets/icon-64.png"/>
          <bt:Image id="Icon80" DefaultValue="https://ColinZeal42.github.io/outlook-filer/assets/icon-128.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Html" DefaultValue="https://ColinZeal42.github.io/outlook-filer/commands.html"/>
          <bt:Url id="Setup.Html" DefaultValue="https://ColinZeal42.github.io/outlook-filer/setup.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="AddInName" DefaultValue="HMF Email Filer"/>
          <bt:String id="SetupLabel" DefaultValue="HMF Setup"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="AddInDescription" DefaultValue="Files sent emails into matching case folders."/>
          <bt:String id="SetupDesc" DefaultValue="Connect to Microsoft to enable automatic email filing."/>
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
